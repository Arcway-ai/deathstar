[Unit]
Description=DeathStar Remote Runtime
After=network-online.target docker.service
Requires=docker.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/deathstar/repo
ExecStartPre=/opt/deathstar/render-runtime-env.sh
ExecStartPre=/opt/deathstar/sync-runtime.sh
ExecStart=/opt/deathstar/start-runtime.sh
ExecStop=/opt/deathstar/stop-runtime.sh
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target
