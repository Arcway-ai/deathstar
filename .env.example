# Local CLI and Terraform defaults
DEATHSTAR_PROJECT_NAME=deathstar
DEATHSTAR_REGION=us-west-1
DEATHSTAR_AWS_PROFILE=default
DEATHSTAR_TERRAFORM_DIR=terraform/environments/aws-ec2
DEATHSTAR_INSTANCE_TYPE=t3.large
DEATHSTAR_ROOT_VOLUME_SIZE_GB=30
DEATHSTAR_DATA_VOLUME_SIZE_GB=200

# Parameter Store locations for remote-only secrets.
# Store the values in AWS SSM Parameter Store, not in this file.
DEATHSTAR_OPENAI_PARAMETER_NAME=/deathstar/providers/openai/api_key
DEATHSTAR_ANTHROPIC_PARAMETER_NAME=/deathstar/providers/anthropic/api_key
DEATHSTAR_GOOGLE_PARAMETER_NAME=/deathstar/providers/google/api_key
DEATHSTAR_VERTEX_PARAMETER_NAME=/deathstar/providers/vertex/service_account_key
DEATHSTAR_GITHUB_PARAMETER_NAME=/deathstar/integrations/github/token

# Vertex AI (Google Cloud) — alternative to Google AI Studio.
# Use this if you have GCP credits and want billing through your GCP project.
# Store a GCP credential config in SSM via: deathstar secrets put --provider vertex
#
# Auth options (choose one):
#   Option A — Workload Identity Federation (recommended, no static keys):
#     1. Create a Workload Identity Pool + AWS provider in GCP
#     2. Grant the pool access to a service account with "Vertex AI User" role
#     3. Download the "credential configuration" JSON from the pool
#     4. Store it via: deathstar secrets put --provider vertex
#     See: https://cloud.google.com/iam/docs/workload-identity-federation-with-other-clouds
#
#   Option B — Service account key (if your org policy allows):
#     1. Create a service account with "Vertex AI User" role
#     2. Download the JSON key
#     3. Store it via: deathstar secrets put --provider vertex
DEATHSTAR_VERTEX_PROJECT_ID=
DEATHSTAR_VERTEX_LOCATION=us-central1

# Optional off-instance backups
DEATHSTAR_CREATE_BACKUP_BUCKET=false
DEATHSTAR_BACKUP_BUCKET_NAME=
DEATHSTAR_FORCE_DESTROY_BACKUP_BUCKET=false

# Optional future-safe ingress controls
DEATHSTAR_ENABLE_WEB_UI=false
DEATHSTAR_WEB_UI_PORT=8443
DEATHSTAR_WEB_UI_ALLOWED_CIDRS=

# Optional git identity for automated commits
DEATHSTAR_GIT_AUTHOR_NAME=DeathStar
DEATHSTAR_GIT_AUTHOR_EMAIL=deathstar@local

# Recommended private operator network
DEATHSTAR_ENABLE_TAILSCALE=true
DEATHSTAR_ENABLE_TAILSCALE_SSH=true
DEATHSTAR_TAILSCALE_AUTH_PARAMETER_NAME=/deathstar/integrations/tailscale/auth_key
# Leave blank to default to the project name.
DEATHSTAR_TAILSCALE_HOSTNAME=
# Optional comma-separated tailnet tags for the DeathStar node.
# Leave blank unless you have matching tag owners and ACLs defined.
DEATHSTAR_TAILSCALE_ADVERTISE_TAGS=

# Optional bearer token for the remote control API.
# When set, all endpoints except /v1/health require Authorization: Bearer <token>.
# Leave blank to disable authentication (only safe when the API is only reachable over the tailnet).
DEATHSTAR_API_TOKEN=

# GitHub OAuth App client ID for `deathstar github setup`.
# Create an OAuth App at https://github.com/settings/applications/new with "Enable Device Flow" checked.
# Set this to the Client ID from that app.
DEATHSTAR_GITHUB_APP_CLIENT_ID=

# Tailscale OAuth client for `deathstar tailscale setup` and automatic cleanup.
# Create an OAuth client at https://login.tailscale.com/admin/settings/oauth
# with scopes: "Auth Keys: Write" + "Devices: Read" + "Devices: Write".
# When both are set, `deathstar upgrade` auto-removes stale Tailscale nodes.
DEATHSTAR_TAILSCALE_OAUTH_CLIENT_ID=
DEATHSTAR_TAILSCALE_OAUTH_CLIENT_SECRET=

# GitHub webhook secret for real-time event delivery (optional).
# When set, the server accepts GitHub webhooks at POST /web/api/webhooks/github.
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# GitHub polling interval in seconds (default: 10).
# The poller checks for pushes, PR updates, and CI status when GITHUB_TOKEN is set.
GITHUB_POLL_INTERVAL=10

# Local CLI transport defaults
DEATHSTAR_REMOTE_TRANSPORT=auto
DEATHSTAR_CONNECT_TRANSPORT=auto
